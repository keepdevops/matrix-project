#!/bin/bash
#
# swarm-ctl - Matrix Swarm Control Utility
# Manage models, agents, and services for the Matrix Swarm
#

CONFIG_FILE="swarm-config.json"
MODELS_DIR="/Users/Shared/models"
LLAMA_SERVER="/Users/Shared/models/llama-server"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check for jq dependency
check_jq() {
    if ! command -v jq &> /dev/null; then
        echo -e "${RED}Error: jq is required but not installed.${NC}"
        echo "Install with: brew install jq"
        exit 1
    fi
}

# List available models
list_models() {
    echo -e "${BLUE}=== Available Models ===${NC}"
    if [ -d "$MODELS_DIR" ]; then
        local count=1
        for model in "$MODELS_DIR"/*.gguf; do
            if [ -f "$model" ]; then
                local size=$(du -h "$model" | cut -f1)
                echo -e "  ${GREEN}[$count]${NC} $(basename "$model") ${YELLOW}($size)${NC}"
                ((count++))
            fi
        done
        if [ $count -eq 1 ]; then
            echo -e "  ${YELLOW}No .gguf models found in $MODELS_DIR/${NC}"
        fi
    else
        echo -e "  ${RED}Models directory not found: $MODELS_DIR${NC}"
    fi
}

# Show current configuration
show_config() {
    echo -e "${BLUE}=== Current Configuration ===${NC}"
    if [ -f "$CONFIG_FILE" ]; then
        echo -e "\n${GREEN}Architect (8080):${NC}"
        jq -r '.agents.architect.model' "$CONFIG_FILE"

        echo -e "\n${GREEN}Logic (8081):${NC}"
        jq -r '.agents.logic.model' "$CONFIG_FILE"

        echo -e "\n${GREEN}Utility (8082):${NC}"
        jq -r '.agents.utility.model' "$CONFIG_FILE"
    else
        echo -e "${RED}Config file not found: $CONFIG_FILE${NC}"
    fi
}

# Set model for an agent
set_model() {
    local agent="$1"
    local model="$2"

    if [ -z "$agent" ] || [ -z "$model" ]; then
        echo -e "${RED}Usage: swarm-ctl set <agent> <model>${NC}"
        echo "  agent: architect, logic, or utility"
        echo "  model: path to .gguf file (e.g., models/llama-3.1-8b-Q4_K_M.gguf)"
        return 1
    fi

    # Validate agent name
    case "$agent" in
        architect|logic|utility) ;;
        *)
            echo -e "${RED}Invalid agent: $agent${NC}"
            echo "Valid agents: architect, logic, utility"
            return 1
            ;;
    esac

    # Check if model file exists
    if [ ! -f "$model" ]; then
        echo -e "${RED}Model file not found: $model${NC}"
        return 1
    fi

    # Update config
    local tmp=$(mktemp)
    jq ".agents.$agent.model = \"$model\"" "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

    echo -e "${GREEN}Updated $agent to use: $model${NC}"
    echo -e "${YELLOW}Run 'swarm-ctl restart' to apply changes${NC}"
}

# Set GPU layers for an agent
set_gpu() {
    local agent="$1"
    local layers="$2"

    if [ -z "$agent" ] || [ -z "$layers" ]; then
        echo -e "${RED}Usage: swarm-ctl gpu <agent> <layers>${NC}"
        echo "  agent: architect, logic, or utility"
        echo "  layers: number of GPU layers (0-99, or 99 for all)"
        return 1
    fi

    case "$agent" in
        architect|logic|utility) ;;
        *)
            echo -e "${RED}Invalid agent: $agent${NC}"
            return 1
            ;;
    esac

    local tmp=$(mktemp)
    jq ".agents.$agent.gpu_layers = $layers" "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

    echo -e "${GREEN}Updated $agent GPU layers to: $layers${NC}"
}

# Generate matrix script from config
generate_matrix() {
    echo -e "${BLUE}Generating matrix script from config...${NC}"

    local arch_model=$(jq -r '.agents.architect.model' "$CONFIG_FILE")
    local arch_port=$(jq -r '.agents.architect.port' "$CONFIG_FILE")
    local arch_gpu=$(jq -r '.agents.architect.gpu_layers' "$CONFIG_FILE")

    local logic_model=$(jq -r '.agents.logic.model' "$CONFIG_FILE")
    local logic_port=$(jq -r '.agents.logic.port' "$CONFIG_FILE")
    local logic_gpu=$(jq -r '.agents.logic.gpu_layers' "$CONFIG_FILE")

    local util_model=$(jq -r '.agents.utility.model' "$CONFIG_FILE")
    local util_port=$(jq -r '.agents.utility.port' "$CONFIG_FILE")
    local util_gpu=$(jq -r '.agents.utility.gpu_layers' "$CONFIG_FILE")

    cat > matrix << 'EOF_MARKER'
#!/bin/bash
# Auto-generated from swarm-config.json
# Use 'swarm-ctl' to modify configuration

LLAMA_SERVER="/Users/Shared/models/llama-server"

case "$1" in
  up)
    echo "⚡️ Booting Matrix Swarm (LLM Engines)..."
    mkdir -p logs

    # Start LLMs in the background
EOF_MARKER
    echo "    \$LLAMA_SERVER -m $arch_model --port $arch_port -ngl $arch_gpu > logs/$arch_port.log 2>&1 &" >> matrix
    echo "    \$LLAMA_SERVER -m $logic_model --port $logic_port -ngl $logic_gpu > logs/$logic_port.log 2>&1 &" >> matrix
    echo "    \$LLAMA_SERVER -m $util_model --port $util_port -ngl $util_gpu > logs/$util_port.log 2>&1 &" >> matrix
    cat >> matrix << 'EOF_MARKER'

    # Start the C++ Coordinator
    ./coordinator > logs/coordinator.log 2>&1 &

    echo "⏳ Waiting for engines to warm up..."
    sleep 5

    echo "🌐 Opening Matrix UI on Port 80..."
    open http://localhost:80
    ;;
  down)
    echo "🛑 Killing Swarm..."
    pkill -f llama-server
    pkill -f "./coordinator"
    # Optional: also stop docker containers
    docker-compose down
    ;;
  status)
    echo "📊 Swarm Status:"
EOF_MARKER
    echo "    echo \"  Architect ($arch_port): \\\$(lsof -i :$arch_port | grep -q LISTEN && echo '\033[0;32mRUNNING\033[0m' || echo '\033[0;31mSTOPPED\033[0m')\"" >> matrix
    echo "    echo \"  Logic ($logic_port): \\\$(lsof -i :$logic_port | grep -q LISTEN && echo '\033[0;32mRUNNING\033[0m' || echo '\033[0;31mSTOPPED\033[0m')\"" >> matrix
    echo "    echo \"  Utility ($util_port): \\\$(lsof -i :$util_port | grep -q LISTEN && echo '\033[0;32mRUNNING\033[0m' || echo '\033[0;31mSTOPPED\033[0m')\"" >> matrix
    cat >> matrix << 'EOF_MARKER'
    echo "  Coordinator (8000): $(lsof -i :8000 | grep -q LISTEN && echo '\033[0;32mRUNNING\033[0m' || echo '\033[0;31mSTOPPED\033[0m')"
    ;;
  *)
    echo "Usage: ./matrix {up|down|status}"
    ;;
esac
EOF_MARKER
    chmod +x matrix
    echo -e "${GREEN}matrix script updated!${NC}"
}

# Restart all services
restart_services() {
    echo -e "${BLUE}Restarting Matrix Swarm...${NC}"

    # Generate fresh matrix script
    generate_matrix

    # Stop existing services
    echo "Stopping services..."
    pkill -f llama-server 2>/dev/null
    pkill -f "./coordinator" 2>/dev/null
    sleep 2

    # Start services
    echo "Starting services..."
    ./matrix up
}

# Show status
show_status() {
    echo -e "${BLUE}=== Swarm Status ===${NC}"

    local arch_port=$(jq -r '.agents.architect.port' "$CONFIG_FILE")
    local logic_port=$(jq -r '.agents.logic.port' "$CONFIG_FILE")
    local util_port=$(jq -r '.agents.utility.port' "$CONFIG_FILE")

    echo -n "  Architect ($arch_port): "
    lsof -i :$arch_port 2>/dev/null | grep -q LISTEN && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"

    echo -n "  Logic ($logic_port): "
    lsof -i :$logic_port 2>/dev/null | grep -q LISTEN && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"

    echo -n "  Utility ($util_port): "
    lsof -i :$util_port 2>/dev/null | grep -q LISTEN && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"

    echo -n "  Coordinator (8000): "
    lsof -i :8000 2>/dev/null | grep -q LISTEN && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"

    echo -n "  Docker UI: "
    docker ps 2>/dev/null | grep -q matrix-ui && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}"
}

# Interactive model selection
interactive_set() {
    local agent="$1"

    if [ -z "$agent" ]; then
        echo -e "${RED}Usage: swarm-ctl pick <agent>${NC}"
        echo "  agent: architect, logic, or utility"
        return 1
    fi

    case "$agent" in
        architect|logic|utility) ;;
        *)
            echo -e "${RED}Invalid agent: $agent${NC}"
            return 1
            ;;
    esac

    echo -e "${BLUE}Select model for $agent:${NC}"

    local models=()
    local count=1
    for model in "$MODELS_DIR"/*.gguf; do
        if [ -f "$model" ]; then
            models+=("$model")
            local size=$(du -h "$model" | cut -f1)
            echo -e "  ${GREEN}[$count]${NC} $(basename "$model") ${YELLOW}($size)${NC}"
            ((count++))
        fi
    done

    if [ ${#models[@]} -eq 0 ]; then
        echo -e "${RED}No models found in $MODELS_DIR${NC}"
        return 1
    fi

    echo -n "Enter selection (1-$((count-1))): "
    read selection

    if [[ "$selection" =~ ^[0-9]+$ ]] && [ "$selection" -ge 1 ] && [ "$selection" -lt "$count" ]; then
        local selected_model="${models[$((selection-1))]}"
        set_model "$agent" "$selected_model"
    else
        echo -e "${RED}Invalid selection${NC}"
        return 1
    fi
}

# Print usage
print_usage() {
    echo -e "${BLUE}Matrix Swarm Control Utility${NC}"
    echo ""
    echo "Usage: swarm-ctl <command> [args]"
    echo ""
    echo "Commands:"
    echo "  models          List available models in models/"
    echo "  config          Show current configuration"
    echo "  status          Show service status"
    echo ""
    echo "  set <agent> <model>   Set model for agent"
    echo "  pick <agent>          Interactive model selection"
    echo "  gpu <agent> <layers>  Set GPU layers for agent"
    echo ""
    echo "  generate        Generate matrix script from config"
    echo "  restart         Restart all services with current config"
    echo ""
    echo "Agents: architect, logic, utility"
    echo ""
    echo "Examples:"
    echo "  swarm-ctl models"
    echo "  swarm-ctl set architect models/llama-3.1-8b-Q4_K_M.gguf"
    echo "  swarm-ctl pick logic"
    echo "  swarm-ctl restart"
}

# Main
check_jq

case "$1" in
    models|list)
        list_models
        ;;
    config|show)
        show_config
        ;;
    status)
        show_status
        ;;
    set)
        set_model "$2" "$3"
        ;;
    pick|select)
        interactive_set "$2"
        ;;
    gpu)
        set_gpu "$2" "$3"
        ;;
    generate|gen)
        generate_matrix
        ;;
    restart)
        restart_services
        ;;
    help|--help|-h|"")
        print_usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        print_usage
        exit 1
        ;;
esac
